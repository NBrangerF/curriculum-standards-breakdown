        "text": "斯特鲁普效应",
        "text_hash": "32af76dcfe922042092b0798cc44cfc541fd43a44d987c5a24a9c7fcd196675f",
        "variant_version_id": "lrzv_90db26c82a81f7d0cd49ebb4"
