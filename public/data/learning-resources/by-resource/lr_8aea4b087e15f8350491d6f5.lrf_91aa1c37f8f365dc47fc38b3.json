    {
      "target_block_id": "lrtb_1acddc6c9566e267b13de4db",
      "text": {
        "locale": "zh-Hans-CN",
        "qa_status": "passed",
        "text": "我们要删除的两个文件是用来测试应用程序的。我们在这里不涉及测试。\n如果你停止了你的服务器来做上面提到的终端任务，你必须用 npm start 再次启动它。",
        "text_hash": "3bc9c441a7215b3fb8f6e524bb98822cd53d569707c036f0ee70aa2520fc9e00",
