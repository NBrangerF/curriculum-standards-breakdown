    },
    {
      "target_block_id": "lrtb_50478b407f555dad1266806e",
      "text": {
        "locale": "zh-Hans-CN",
        "qa_status": "passed",
        "text": "当你刷新浏览器时，你应该看到类似这样的东西：",
        "text_hash": "7044a8a4dea8f22780c86d928c3e86dd5c5dc03324a100cdf88d4b77704dcf0c",
        "variant_version_id": "lrzv_b0c8556cb5fc912283155b43"
