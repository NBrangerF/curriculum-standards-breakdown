    {
      "target_block_id": "lrtb_821e18ad28d7085afd2623e6",
      "text": {
        "locale": "zh-Hans-CN",
        "qa_status": "passed",
        "text": "css\n.container {\n  column-width: 200px;\n}",
        "text_hash": "0deb6fe156676346fa4744084ef0ac5c7771d8ea03c432afc60c19c49b7c867f",
        "variant_version_id": "lrzv_b49152cecd63174252900813"
