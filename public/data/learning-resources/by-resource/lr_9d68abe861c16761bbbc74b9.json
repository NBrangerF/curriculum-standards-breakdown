    {
      "target_block_id": "lrtb_960a5a68300462904a6719f6",
      "text": {
        "locale": "zh-Hans-CN",
        "qa_status": "passed",
        "text": "给多列增加样式",
        "text_hash": "fe234a50741adb769c1206b5cd40a358720f612f0ddb2a0d883faffe4c773a3b",
