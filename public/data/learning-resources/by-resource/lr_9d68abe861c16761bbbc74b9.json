      "text": {
        "locale": "zh-Hans-CN",
        "qa_status": "passed",
        "text": "现阶段，增加旧属性 page-break-inside: avoid 能够获得更好的浏览器支持。",
        "text_hash": "0ebb18abc8e92e231440c1e24c89e7e598d3c2b70e152ddea16ca46a2322841a",
        "variant_version_id": "lrzv_b49152cecd63174252900813"
      },
      "type": "paragraph"
    },
    {
      "target_block_id": "lrtb_bbe998283518e85559195f86",
      "text": {
        "locale": "zh-Hans-CN",
        "qa_status": "passed",
        "text": "css\n.card {\n  break-inside: avoid;\n  page-break-inside: avoid;\n  background-color: rgb(207, 232, 220);\n  border: 2px solid rgb(79, 185, 227);\n  padding: 10px;\n  margin: 0 0 1em 0;\n}",
        "text_hash": "2eacd451260031de6d43edd6d3931c22a3e3c489827c5b27c1b050ac7067876f",
