        "locale": "zh-Hans-CN",
        "qa_status": "passed",
        "text": "css\nhtml {\n  font-family: sans-serif;\n}",
        "text_hash": "6bf5839bc3d448bdd4eba76bb93bd38fd5cabc9235fb8ff14507a8d295f075e4",
        "variant_version_id": "lrzv_736e80594ffac22976508677"
      },
