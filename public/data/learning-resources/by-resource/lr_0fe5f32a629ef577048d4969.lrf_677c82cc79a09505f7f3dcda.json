    {
      "target_block_id": "lrtb_1732cff801d3810c0571bb88",
      "text": {
        "locale": "zh-Hans-CN",
        "qa_status": "passed",
        "text": "掌握了上一篇文章中的定位的基础知识，我们将着眼于实现一些现实中的例子，来演示你能用定位来做什么。",
        "text_hash": "4507e02ac8a966d7133668a5dbafd12a88e020c15593818440d83f956cea6f3f",
        "variant_version_id": "lrzv_736e80594ffac22976508677"
      },
      "type": "paragraph"
    },
    {
      "target_block_id": "lrtb_6ab1f9813f9bc93972df9325",
      "text": {
        "locale": "zh-Hans-CN",
        "qa_status": "passed",
        "text": "前提：",
        "text_hash": "60df7f5b49d0fd69c1a1ee4bda41ede8b786ae9d162b8a9a73e264bbf703119b",
        "variant_version_id": "lrzv_736e80594ffac22976508677"
      },
      "type": "paragraph"
    },
