      "type": "paragraph"
    },
    {
      "target_block_id": "lrtb_e68f98951ad823d516efe01a",
      "text": {
        "locale": "zh-Hans-CN",
        "qa_status": "passed",
        "text": "css\naside {\n  background-color: #a60000;\n  color: white;",
        "text_hash": "29d3552938df0157d6cc2eca316dc9d3278d5d05cdca48fa3b2124cdd270d2f1",
        "variant_version_id": "lrzv_736e80594ffac22976508677"
      },
      "type": "paragraph"
    },
    {
      "target_block_id": "lrtb_835ac442cdac985ed87c900e",
      "text": {
        "locale": "zh-Hans-CN",
        "qa_status": "passed",
        "text": "width: 340px;\n  height: 98%;\n  padding: 10px 1%;",
        "text_hash": "7f68347d4b546aa6535809f2119d5f6606a21b3fea93886045ab8032bf737192",
        "variant_version_id": "lrzv_736e80594ffac22976508677"
