        "locale": "zh-Hans-CN",
        "qa_status": "passed",
        "text": "position: fixed;\n  top: 0;\n  right: -370px;",
        "text_hash": "b9bba325a194edc865880cc6be8f9fabf2d51e75e653219394445b22104d5d9a",
        "variant_version_id": "lrzv_736e80594ffac22976508677"
      },
      "type": "paragraph"
