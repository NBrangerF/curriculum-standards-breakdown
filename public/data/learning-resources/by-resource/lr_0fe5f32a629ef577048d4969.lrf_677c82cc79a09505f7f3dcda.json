    {
      "target_block_id": "lrtb_e1f42b1a2ce0c55a8052bbdc",
      "text": {
        "locale": "zh-Hans-CN",
        "qa_status": "passed",
        "text": "列表消息盒子",
        "text_hash": "20e7c9cc06e8cfa6483dceadda437039f824c9d04073dba65d62b127e6e85d66",
        "variant_version_id": "lrzv_736e80594ffac22976508677"
