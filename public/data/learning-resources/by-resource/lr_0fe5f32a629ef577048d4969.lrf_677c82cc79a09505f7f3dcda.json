    },
    {
      "target_block_id": "lrtb_556e543bb9dbaa1faa812518",
      "text": {
        "locale": "zh-Hans-CN",
        "qa_status": "passed",
        "text": "开始前，在开闭标签之间添加下面的代码：",
        "text_hash": "2965804c11c49e897f240bdaec9f337b9e479bd018e65586b6b28b114900b90f",
        "variant_version_id": "lrzv_736e80594ffac22976508677"
      },
      "type": "paragraph"
    },
    {
      "target_block_id": "lrtb_ed08c1ce005b5ee69ccaae24",
