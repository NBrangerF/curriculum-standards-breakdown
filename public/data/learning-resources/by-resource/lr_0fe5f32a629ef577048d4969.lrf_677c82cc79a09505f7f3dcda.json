    {
      "target_block_id": "lrtb_bae19ec255583c84aab5670b",
      "text": {
        "locale": "zh-Hans-CN",
        "qa_status": "passed",
        "text": "下一步工作是样式化我们的面板，现在开始吧！",
        "text_hash": "a15b6d15d5e38918c16debfc772101fd009ed5ef500ff29228f9851bfa3f72cc",
        "variant_version_id": "lrzv_736e80594ffac22976508677"
