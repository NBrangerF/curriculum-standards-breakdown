    {
      "target_block_id": "lrtb_b857d61e43a0ff4a486cb882",
      "text": {
        "locale": "zh-Hans-CN",
        "qa_status": "passed",
        "text": "基于 Web 的音频/视频执行控件不应该成为问题，对吗？让我们来调查一下。",
        "text_hash": "8096e1654a4c98dae29da50ed543b9dd76c6126ff84e237e7a90b265d142454a",
