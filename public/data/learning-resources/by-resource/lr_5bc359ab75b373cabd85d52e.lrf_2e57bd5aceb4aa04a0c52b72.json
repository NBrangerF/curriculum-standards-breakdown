    {
      "target_block_id": "lrtb_876ce0d8b14a922fe2020406",
      "text": {
        "locale": "zh-Hans-CN",
        "qa_status": "passed",
        "text": "控件属性提供播放/暂停按钮、搜索栏等 - 你期望从媒体播放器获得的基本控件。它看起来像在 Firefox 和 Chrome:",
        "text_hash": "b811516bd76adea6d7b7475660d74aa9e1b70d71b13a150762e846ab7a8642ed",
