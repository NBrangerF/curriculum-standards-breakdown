      "text": {
        "locale": "zh-Hans-CN",
        "qa_status": "passed",
        "text": "Your browser doesn't support HTML5 audio. Here is a\n     link to the audio  instead.",
        "text_hash": "ae855ae84ced645449450a40c80ea1faf724afec8b05af4a7ed1fa8a9d1b7f4b",
