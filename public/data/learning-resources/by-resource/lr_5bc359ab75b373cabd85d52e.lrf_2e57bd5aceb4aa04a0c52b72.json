    {
      "target_block_id": "lrtb_a3f741e6c299906c2a1bae9a",
      "text": {
        "locale": "zh-Hans-CN",
        "qa_status": "passed",
        "text": "HTML5 视频和音频实例甚至附带一组内置控件，允许你直接在盒子控制媒体。例如 (请参阅本地控件.html 源代码和实时演示):",
        "text_hash": "9e03dfa4c5e6145bf9aaaaeea7558c4175e223740d96270c6ec662bf213af8ae",
        "variant_version_id": "lrzv_3fe8b1a8a87aaf65175dab66"
      },
      "type": "paragraph"
    },
    {
      "target_block_id": "lrtb_1102d254adccc2406e1ce37a",
      "text": {
        "locale": "zh-Hans-CN",
        "qa_status": "passed",
        "text": "html",
