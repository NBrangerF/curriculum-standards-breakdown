        "text": "前提",
        "text_hash": "bb9f5f19c7f14c1c83bc2f60c8b6b533ef8da215dc1b1ce8125546531c5951db",
        "variant_version_id": "lrzv_d4ed6aed0ac41d192a6c502d"
