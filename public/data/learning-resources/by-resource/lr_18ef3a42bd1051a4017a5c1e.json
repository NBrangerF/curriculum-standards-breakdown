      "text": {
        "locale": "zh-Hans-CN",
        "qa_status": "passed",
        "text": "学习客户端框架之前，首先你应扎实掌握核心 web 语言的基础知识——HTML、CSS，尤其是 JavaScript。",
        "text_hash": "ad955ad9ed95c565cae9fc9c062c3998036b65185a9f59e37934d5e8743b27e2",
        "variant_version_id": "lrzv_d4ed6aed0ac41d192a6c502d"
