    {
      "target_block_id": "lrtb_2b19f4c0cd55b078fcd85124",
      "text": {
        "locale": "zh-Hans-CN",
        "qa_status": "passed",
        "text": "本章建立在4年级和5年级所发展的能量概念基础之上。我们通过详细说明不同类型并对其进行分类，扩展可再生和不可再生能源来源的概念。本章还介绍化石燃料的概念，这与学习者下学期将在“地球及其以外”中学习的内容相衔接。",
        "text_hash": "8d7c3b4ac7abc22d07a022bc951ff7923454ed7dff2bd640d6122b63da7a073b",
        "variant_version_id": "lrzv_0b23a2505de6966bc4bc64e5"
      },
      "type": "paragraph"
    },
