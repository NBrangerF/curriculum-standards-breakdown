        {
          "target_block_id": "lrtb_eb8bd3af3c44d8b9bc1ea9d2",
          "text": {
            "locale": "zh-Hans-CN",
            "qa_status": "passed",
            "text": "1 周",
            "text_hash": "3cecefe8c4c0119af9e752f4f1f91ab7e98bbe5ddf9907b58da409a716f533c4",
            "variant_version_id": "lrzv_609c202535e82da3a2effe82"
          },
          "type": "paragraph"
