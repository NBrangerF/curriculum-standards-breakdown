    {
      "blocks": [
        {
          "target_block_id": "lrtb_e53e3a46d7ea8c535dc21098",
          "text": {
            "locale": "zh-Hans-CN",
            "qa_status": "passed",
            "text": "图像压缩",
            "text_hash": "1249ebc059247fc4cfabcd36d893cca388b3383503c274d4666e862d6e98bfeb",
            "variant_version_id": "lrzv_5a2a5789404a32084670199b"
          },
          "type": "heading"
