{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "prerequisite-edge.schema.json",
  "type": "object",
  "required": ["id", "source", "target", "type", "directed", "necessity", "rationale", "evidenceRefs", "confidence", "reviewStatus", "reviewedByRole", "reviewedAt", "version"],
  "properties": {
    "id": { "type": "string", "pattern": "^pre:" },
    "source": { "type": "string", "pattern": "^kp:" },
    "target": { "type": "string", "pattern": "^kp:" },
    "type": { "const": "prerequisite" },
    "directed": { "const": true },
    "necessity": { "enum": ["required", "recommended"] },
    "rationale": { "type": "string", "minLength": 1 },
    "evidenceRefs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "confidence": { "enum": ["high", "medium", "low"] },
    "reviewStatus": { "enum": ["candidate", "approved", "disputed", "retired"] },
    "reviewedByRole": { "type": "string", "minLength": 1 },
    "reviewedAt": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 }
  }
}
