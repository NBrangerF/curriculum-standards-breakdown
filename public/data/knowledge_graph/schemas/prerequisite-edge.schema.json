{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "prerequisite-edge.schema.json",
  "type": "object",
  "required": ["id", "source", "target", "type", "directed", "necessity", "rationale", "evidenceRefs", "confidence", "reviewStatus", "version"],
  "properties": {
    "id": { "type": "string", "pattern": "^pre:" },
    "source": { "type": "string", "pattern": "^kp:" },
    "target": { "type": "string", "pattern": "^kp:" },
    "type": { "const": "prerequisite" },
    "directed": { "const": true },
    "necessity": { "enum": ["required", "recommended", "undetermined"] },
    "rationale": { "type": "string", "minLength": 1 },
    "evidenceRefs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "confidence": { "enum": ["high", "medium", "low"] },
    "confidenceScore": { "type": "number", "minimum": 0, "maximum": 1 },
    "relationType": { "enum": ["curriculum_sequence_candidate", "grade_band_bridge_candidate"] },
    "method": { "type": "string", "minLength": 1 },
    "provenance": { "enum": ["official", "extracted", "editorial", "rule_generated", "ai_generated"] },
    "reviewStatus": { "enum": ["candidate", "approved", "disputed", "retired"] },
    "reviewedByRole": { "type": "string", "minLength": 1 },
    "reviewedAt": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 }
  },
  "allOf": [{
    "if": { "properties": { "reviewStatus": { "const": "approved" } }, "required": ["reviewStatus"] },
    "then": { "required": ["reviewedByRole", "reviewedAt"] }
  }]
}
