# Local textbook binaries live on the external X9 Pro volume.
# Do not use a VITE_ prefix: this path must never be exposed to browser code.
TEXTBOOK_LIBRARY_ROOT=/Volumes/X9 Pro/kebiao-library

# Optional production object-storage/CDN origin. When set, viewer sessions use
# signed/public remote URLs instead of the local Range endpoint.
# TEXTBOOK_ASSET_BASE_URL=https://assets.example.com/textbooks
