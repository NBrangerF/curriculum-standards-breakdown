# Local textbook binaries live on the external X9 Pro volume.
# Do not use a VITE_ prefix: this path must never be exposed to browser code.
TEXTBOOK_LIBRARY_ROOT=/Volumes/X9 Pro/kebiao-library

# Optional production object-storage/CDN origin. When set, the API proxies
# registered PDF objects through the same-origin Range endpoint so readers do
# not need direct access to the storage provider's hostname.
# TEXTBOOK_ASSET_BASE_URL=https://textbook-assets.example.workers.dev
