{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "buildCommand": "npm run build",
    "installCommand": "npm install",
    "outputDirectory": "dist",
    "functions": {
        "api/v1/[...path].ts": {
            "maxDuration": 60,
            "includeFiles": "{public/data/**,data/textbooks/library-state/**,docs/api/**,node_modules/swagger-ui-dist/swagger-ui.css,node_modules/swagger-ui-dist/swagger-ui-bundle.js}"
        }
    },
    "rewrites": [
        {
            "source": "/api/v1/:path*",
            "destination": "/api/v1/[...path]"
        },
        {
            "source": "/api",
            "destination": "/index.html"
        },
        {
            "source": "/((?!api|data|assets|.*\\..*).*)",
            "destination": "/index.html"
        }
    ]
}
